│   └── download/route.js       GET   — Download report as CSV/JSON
├── sla/route.js                GET   — SLA monitoring data
├── performance/route.js        GET   — Performance metrics
├── citizen-engagement/route.js GET   — Citizen engagement stats
└── health/route.js             GET   — Health check endpoint
```

