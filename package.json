    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "mongodb": "^7.1.0",
    "mongoose": "^8.1.0",
    "next": "14.2.15",
    "next-cloudinary": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
